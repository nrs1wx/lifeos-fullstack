# Local SQLite database. For production Render+Neon use a Postgres URL like:
# DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
DATABASE_URL="file:./dev.db"

# Секрет для подписи JWT-токенов. Впишите любую длинную случайную строку.
JWT_SECRET="change-this-to-a-long-random-string"

# Порт, на котором поднимется backend
PORT=8787

# Адрес фронтенда, которому разрешён доступ к API (CORS). On production replace with Vercel/Netlify URL.
CORS_ORIGIN="http://localhost:3000"

# App display name used in logs and AI prompts.
APP_NAME="LifeOS"

# AI provider: gemini, groq, or anthropic.
AI_PROVIDER="gemini"

# Gemini API key.
# How to get it: https://aistudio.google.com/app/apikey -> Create API key
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"

# Groq API key.
# How to get it: https://console.groq.com/keys -> Create API Key
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# Anthropic API key.
# How to get it: https://console.anthropic.com/ -> Settings -> API Keys -> Create Key
# If no provider key is set, the server still starts, but AI chat returns a clear setup error.
ANTHROPIC_API_KEY=""

# Claude model for Anthropic provider.
ANTHROPIC_MODEL="claude-haiku-4-5-20251001"
